# Warcraft Logs API credentials (client-credentials flow, public API).
# Create a client at https://www.warcraftlogs.com/api/clients
#   - Do NOT check "Public Client" (that disables the secret / switches to PKCE)
#   - Redirect URL is unused for this flow; http://localhost is fine
# Then copy this file to .env and fill in the values. .env is gitignored.

WCL_CLIENT_ID=your_client_id_here
WCL_CLIENT_SECRET=your_client_secret_here
